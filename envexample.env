# QR Event System Environment Configuration
# ===========================================
# Copy this file to .env and update with your actual values

# Mailtrap Email Configuration
# ---------------------------
# Sign up at https://mailtrap.io and get your SMTP credentials from the inbox settings

# Mailtrap SMTP credentials
MAIL_USERNAME=your_mailtrap_username
MAIL_PASSWORD=your_mailtrap_password

# Email sender configuration
MAIL_FROM=noreply@example.com
MAIL_FROM_NAME=QR Event System

# Mailtrap SMTP server settings (usually don't need to change these)
MAIL_SERVER=sandbox.smtp.mailtrap.io
MAIL_PORT=587

# Connection security settings (default values work with Mailtrap)
MAIL_STARTTLS=True
MAIL_SSL_TLS=False
USE_CREDENTIALS=True
VALIDATE_CERTS=True 